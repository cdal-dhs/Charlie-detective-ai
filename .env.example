# --- LLM (LiteLLM router) ---
# v1.25.0 : gemma4:31b (non-reasoning, multimodal) est le modèle principal sur
# toutes les tâches. Fallback = glm-5.2:cloud (reasoning, thinking High/Max).
# Provider Ollama Pro Cloud = openai/<model> + api_base https://ollama.com/v1
# (JAMAIS ollama_chat/<model> → force vers Ollama local inexistant sur le VPS).
OLLAMA_PRO_API_KEY=
OLLAMA_PRO_BASE_URL=https://ollama.com/v1
LLM_MODEL_DEFAULT=openai/gemma4:31b

# Fallback : glm-5.2:cloud via Ollama Pro (reasoning model)
OPENROUTER_API_KEY=
LLM_MODEL_FALLBACK=openai/glm-5.2:cloud

# Modèle dédié à la classification
LLM_MODEL_CLASSIFIER=openai/gemma4:31b

# Modèle chat Charlie (cockpit + Slack Bot)
LLM_MODEL_CHAT=openai/gemma4:31b

# v1.22.7 : modèle dédié à la qualification prospect (cas de figure + questions)
LLM_MODEL_QUALIFIER=openai/gemma4:31b

# --- Resend (livraison brouillons à Cyril) ---
RESEND_API_KEY=
RESEND_FROM=agent@digitalhs.biz
DRAFT_RECIPIENT=cdal@digitalhs.biz  # legacy, conservé pour alertes
# v1.21.7 : fallback Resend IMAP — Daniel en to, Cyril en cc (traçabilité)
DRAFT_RECIPIENT_TO=contact@detectivebelgique.be
DRAFT_RECIPIENT_CC=cdal@digitalhs.biz

# --- Cerveau2-Det (second cerveau vault) ---
CERVEAU2_BASE_URL=https://cerveau2-det.digitalhs.biz
CERVEAU2_API_SECRET=
CERVEAU2_LIMIT=3

# --- RAG ---
# v1.24.2 : RAG en pause par défaut. L'approche déterministe (qualification_builder
# + few-shot Daniel) est plus fiable. Le RAG était cassé sur les 3 boîtes depuis
# 2026-05-28 (pairs_vec vide / manquant). Ne réactiver (RAG_ENABLED=true) qu'après
# avoir re-bootstrappé pairs_vec (python -m scripts.bootstrap_embeddings).
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
RAG_TOP_K=5
RAG_ENABLED=false

# --- Polling ---
POLL_INTERVAL_SECONDS=300
PROCESS_SINCE_DATE=2026-06-01  # Charlie ne traite que les mails depuis cette date (vide = tout l'historique)

# --- Tarifs qualification prospect (v1.22.7) ---
DOSSIER_OPENING_FEE=200
REPORT_FEE=150
HOURLY_RATE_DAY=75
HOURLY_RATE_NIGHT_WEEKEND=95

# Catégories déclenchant la génération d'un brouillon (v1.22.7)
DRAFT_CATEGORIES=demande_client,prise_contact

# --- Stockage ---
DATA_DIR=./data
DB_BOITE_1=./data/boite1.sqlite
DB_BOITE_2=./data/boite2.sqlite
DB_BOITE_3=./data/boite3.sqlite
DB_BOITE_4=./data/boite4.sqlite
DB_AGENT_STATE=./data/agent_state.db

