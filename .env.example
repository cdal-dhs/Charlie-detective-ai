# --- Infomaniak IMAP (3 boîtes) ---
IMAP_HOST=mail.infomaniak.com
IMAP_PORT=993

MAILBOX_1_NAME=detective_belgique
MAILBOX_1_USER=contact@detectivebelgique.be
MAILBOX_1_APP_PASSWORD=
MAILBOX_1_BRAND=Detective Belgique
MAILBOX_1_DEFAULT_LANG=fr

MAILBOX_2_NAME=detective_belgium
MAILBOX_2_USER=contact@detectivebelgium.com
MAILBOX_2_APP_PASSWORD=
MAILBOX_2_BRAND=Detective Belgium
MAILBOX_2_DEFAULT_LANG=en

MAILBOX_3_NAME=dpdh_investigations
MAILBOX_3_USER=info@dpdhuinvestigations.be
MAILBOX_3_APP_PASSWORD=
MAILBOX_3_BRAND=DPDH Investigations
MAILBOX_3_DEFAULT_LANG=fr

# --- LLM (LiteLLM router) ---
# Modèle principal : Kimi K2 via Ollama Pro
OLLAMA_PRO_API_KEY=
OLLAMA_PRO_BASE_URL=https://ollama.com/api
LLM_MODEL_DEFAULT=ollama_chat/kimi-k2

# Fallback : OpenRouter
OPENROUTER_API_KEY=
LLM_MODEL_FALLBACK=openrouter/anthropic/claude-sonnet-4

# Modèle dédié à la classification (peut être plus léger/rapide)
LLM_MODEL_CLASSIFIER=ollama_chat/kimi-k2

# --- Resend (livraison brouillons à Cyril) ---
RESEND_API_KEY=
RESEND_FROM=agent@digitalhs.biz
DRAFT_RECIPIENT=cdal@digitalhs.biz

# --- RAG ---
EMBEDDING_MODEL=intfloat/multilingual-e5-large
RAG_TOP_K=5

# --- Polling ---
POLL_INTERVAL_SECONDS=300

# --- Stockage ---
DATA_DIR=./data
DB_BOITE_1=./data/boite1.sqlite
DB_BOITE_2=./data/boite2.sqlite
DB_BOITE_3=./data/boite3.sqlite
DB_AGENT_STATE=./data/agent_state.db

# --- Healthcheck ---
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=8765

# --- Telegram alertes (optionnel V1) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Slack ---
SLACK_WEBHOOK_URL=

# --- Web UI ---
WEB_SECRET_KEY=change-me-in-production-32-char-min
WEB_ENCRYPTION_KEY=another-secret-key-32-chars-long
WEB_BIND_HOST=127.0.0.1
WEB_BIND_PORT=8080
WEB_SESSION_TTL_HOURS=24
ADMIN_EMAIL=cdal@digitalhs.biz
OPERATOR_EMAIL=contact@detectivebelgique.be
MAGIC_LINK_TTL_MINUTES=15

# --- Logs ---
LOG_LEVEL=INFO
