# --- Infomaniak IMAP (3 boîtes) ---
IMAP_HOST=mail.infomaniak.com
IMAP_PORT=993

MAILBOX_1_NAME=detective_belgique
MAILBOX_1_USER=contact@detectivebelgique.be
MAILBOX_1_APP_PASSWORD=
MAILBOX_1_BRAND=Detective Belgique
MAILBOX_1_DEFAULT_LANG=fr

MAILBOX_2_NAME=detective_belgium
MAILBOX_2_USER=contact@detectivebelgium.com
MAILBOX_2_APP_PASSWORD=
MAILBOX_2_BRAND=Detective Belgium
MAILBOX_2_DEFAULT_LANG=en

MAILBOX_3_NAME=dpdh_investigations
MAILBOX_3_USER=info@dpdhuinvestigations.be
MAILBOX_3_APP_PASSWORD=
MAILBOX_3_BRAND=DPDH Investigations
MAILBOX_3_DEFAULT_LANG=fr

# --- LLM (LiteLLM router) ---
# Modèle principal : Kimi K2.6 via Ollama Pro (endpoint OpenAI-compatible)
OLLAMA_PRO_API_KEY=
OLLAMA_PRO_BASE_URL=https://ollama.com/v1
LLM_MODEL_DEFAULT=openai/kimi-k2.6:cloud

# Fallback : GLM 5.1 via Ollama Pro (Claude Sonnet 4 404 sur OpenRouter)
OPENROUTER_API_KEY=
LLM_MODEL_FALLBACK=openai/glm-5.1:cloud

# Modèle dédié à la classification (léger et rapide)
LLM_MODEL_CLASSIFIER=openai/kimi-k2.6:cloud

# --- Resend (livraison brouillons à Cyril) ---
RESEND_API_KEY=
RESEND_FROM=agent@digitalhs.biz
DRAFT_RECIPIENT=cdal@digitalhs.biz  # legacy, conservé pour alertes
# v1.21.7 : fallback Resend IMAP — Daniel en to, Cyril en cc (traçabilité)
DRAFT_RECIPIENT_TO=contact@detectivebelgique.be
DRAFT_RECIPIENT_CC=cdal@digitalhs.biz

# --- Cerveau2-Det (second cerveau vault) ---
CERVEAU2_BASE_URL=https://cerveau2-det.digitalhs.biz
CERVEAU2_API_SECRET=
CERVEAU2_LIMIT=3

# --- RAG ---
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=
RAG_TOP_K=5

# --- Polling ---
POLL_INTERVAL_SECONDS=300
PROCESS_SINCE_DATE=2026-06-01  # Charlie ne traite que les mails depuis cette date (vide = tout l'historique)

# --- Stockage ---
DATA_DIR=./data
DB_BOITE_1=./data/boite1.sqlite
DB_BOITE_2=./data/boite2.sqlite
DB_BOITE_3=./data/boite3.sqlite
DB_AGENT_STATE=./data/agent_state.db

# --- Healthcheck ---
HEALTHCHECK_HOST=127.0.0.1
HEALTHCHECK_PORT=8765

# --- Telegram alertes (optionnel V1) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Slack ---
SLACK_WEBHOOK_URL=

# --- Slack Bot (interactif — Charlie AI sur #detective) ---
SLACK_BOT_TOKEN=           # xoxb-... Bot User OAuth Token
SLACK_SIGNING_SECRET=      # Signing secret de l'app Slack

# --- Web UI ---
WEB_SECRET_KEY=change-me-in-production-32-char-min
WEB_ENCRYPTION_KEY=another-secret-key-32-chars-long
WEB_BIND_HOST=127.0.0.1
WEB_BIND_PORT=8080
WEB_SESSION_TTL_HOURS=24
PUBLIC_BASE_URL=https://detective.digitalhs.biz  # URL publique du Cockpit (pour magic links)
ADMIN_EMAIL=cdal@digitalhs.biz
OPERATOR_EMAIL=contact@detectivebelgique.be
MAGIC_LINK_TTL_MINUTES=15

# --- Logs ---
LOG_LEVEL=INFO
