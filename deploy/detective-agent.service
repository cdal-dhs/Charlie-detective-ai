[Unit]
Description=Detective.be email agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=detective-agent
Group=detective-agent
WorkingDirectory=/opt/detective-agent
Environment="PATH=/opt/detective-agent/venv/bin"
EnvironmentFile=/opt/detective-agent/.env
ExecStart=/opt/detective-agent/venv/bin/python -m app.main
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/detective-agent/data /opt/detective-agent/logs

[Install]
WantedBy=multi-user.target
